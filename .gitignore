# ==========================================

# Developmental AGI Repository .gitignore

# ==========================================

# ---------------------------

# Python Cache

# ---------------------------

**pycache**/
*.py[cod]
*$py.class

# ---------------------------

# Virtual Environments

# ---------------------------

.env
.venv
venv/
env/
ENV/

# ---------------------------

# Python Packaging

# ---------------------------

build/
dist/
*.egg-info/
.eggs/

# ---------------------------

# Jupyter Notebooks

# ---------------------------

.ipynb_checkpoints/

# ---------------------------

# Logs

# ---------------------------

logs/
*.log

# ---------------------------

# Experiment Outputs

# ---------------------------

outputs/
checkpoints/
models/
trained_models/
*.pt
*.pth
*.ckpt

# ---------------------------

# Large Result Files

# ---------------------------

*.npy
*.npz
*.h5

# ---------------------------

# Generated Figures

# ---------------------------

*.png
*.jpg
*.jpeg
*.svg
figures/

# ---------------------------

# Dataset Files

# ---------------------------

data/
datasets/

# ---------------------------

# Temporary Files

# ---------------------------

*.tmp
*.temp
*.swp
*.bak

# ---------------------------

# IDE Files

# ---------------------------

.vscode/
.idea/

# ---------------------------

# MacOS

# ---------------------------

.DS_Store

# ---------------------------

# Windows

# ---------------------------

Thumbs.db

# ---------------------------

# Ignore compiled CUDA kernels

# ---------------------------

*.so
*.dylib
*.dll

# ---------------------------

# Local experiment configs

# ---------------------------

local_config.yaml
secrets.yaml

# ---------------------------

# Keep important files tracked

# ---------------------------

!LICENSE
!README.md
!Paper/
!Core_Proofs/
!Experiments/
!Results/
